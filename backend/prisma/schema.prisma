generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  password     String
  role         String    @default("ADMIN")
  isFirstLogin Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model News {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  summary     String?
  imageUrl    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorId    String?
}

model Contact {
  id          String   @id @default(uuid())
  fullName    String
  company     String?
  phone       String?
  email       String
  inquiryType String
  details     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== CRM 客户管理模型 ====================

// 客户表
model Customer {
  id                  String    @id @default(uuid())
  name                String    // 公司名称
  creditCode          String?   @map("credit_code") // 统一社会信用代码
  industry            String?   // 行业
  scale               String?   // 公司规模
  preferredRoutes     String?   @map("preferred_routes") // 偏好航线（JSON数组）
  settlementType      String?   @map("settlement_type") // 结算方式偏好

  // 客户画像
  level               String?   // 客户等级 A/B/C/D
  type                String?   // 客户类型 direct/peer/agent
  monthlyVolume       Int?      @map("monthly_volume") // 月货量预估(TEU)
  transportModes      String?   @map("transport_modes") // 运输方式（逗号分隔）
  targetRoutes        String?   @map("target_routes") // 目标航线
  requirements        String?   // 特殊需求
  competition         String?   // 竞争情况
  tags                String?   // 标签（逗号分隔）

  // 管理
  status              String    @default("active") // active-正常, public-公海, archived-归档
  ownerId             String?   @map("owner_id") // 归属销售ID
  source              String    @default("manual") // 来源

  // 时间戳
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  lastFollowUpAt      DateTime? @map("last_follow_up_at") // 最后跟进时间

  // 关联
  contacts            ContactPerson[]
  followUps           FollowUp[]
  attachments         CustomerAttachment[]

  @@index([name])
  @@index([status])
  @@index([ownerId])
  @@index([level])
  @@map("customers")
}

// 联系人表
model ContactPerson {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  name        String   // 姓名
  position    String?  // 职位
  phone       String?  // 电话
  wechat      String?  // 微信
  email       String?  // 邮箱
  isPrimary   Boolean  @default(false) @map("is_primary") // 是否主联系人
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("contact_persons")
}

// 跟进记录表
model FollowUp {
  id              String   @id @default(uuid())
  customerId      String   @map("customer_id")
  userId          String   @map("user_id") // 跟进人ID
  method          String   // 跟进方式 phone/wechat/email/visit/other
  content         String   // 跟进内容
  feedback        String?  // 客户反馈
  nextFollowUpAt  DateTime? @map("next_follow_up_at") // 下次跟进提醒
  updateProfile   Boolean  @default(false) @map("update_profile") // 是否同步更新画像
  createdAt       DateTime @default(now()) @map("created_at")

  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([userId])
  @@index([nextFollowUpAt])
  @@map("follow_ups")
}

// 客户附件表
model CustomerAttachment {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  name        String   // 文件名
  type        String   // 文件类型 sop/contract/license/other
  url         String   // 存储路径
  size        Int      // 文件大小(字节)
  uploadedBy  String   @map("uploaded_by") // 上传人ID
  createdAt   DateTime @default(now()) @map("created_at")

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_attachments")
}

// 会员模型
model Member {
  id                     String    @id @default(uuid())
  openid                 String?   @unique
  companyName            String
  contactName            String
  phone                  String
  email                  String?   @unique
  password               String?
  status                 String    @default("PENDING")
  role                   String    @default("MEMBER")
  position               String?
  dazhangguiEnterpriseId String?   @map("dzg_enterprise_id")
  lastLoginAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // 销售联系信息
  salesName    String? // 销售姓名
  salesPhone   String? // 销售电话
  salesMobile  String? // 销售手机
  salesEmail   String? // 销售邮箱

  subscriptions  Subscription[]
  orderQueryLogs OrderQueryLog[]
  memberPortPrefs MemberPortPreference[]

  @@index([openid])
  @@index([status])
  @@index([email])
}

// API Key模型（对外API认证 - 独立于会员系统）
model ApiKey {
  id              String    @id @default(uuid())
  key             String    @unique
  name            String
  description     String?   // 备注说明
  permissions     String?   // JSON字符串存储权限配置
  isActive        Boolean   @default(true)
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  createdByAdminId String?  // 创建者（管理员ID），与会员系统无关
  createdAt       DateTime  @default(now())

  @@index([key])
  @@index([createdByAdminId])
}

// 订阅配额模型
model Subscription {
  id           String   @id @default(uuid())
  memberId     String
  planType     String   @default("FREE")
  monthlyQuota Int      @default(100)
  usedQuota    Int      @default(0)
  periodStart  DateTime
  periodEnd    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

// 运价模型 - SEA FCL only
model FreightRate {
  id    String @id @default(uuid())
  route String? // 航线名称

  // 港口信息
  originPort        String // 起运港
  originPortEn      String? // 起运港英文
  destinationPort   String // 目的港
  destinationPortEn String? // 目的港英文
  viaPort           String? // 中转港
  viaPortEn         String? // 中转港英文
  portArea          String? // 港区

  // 有效期
  validFrom     DateTime // 有效期开始
  validTo       DateTime // 有效期结束
  validityType  String   @default("LONG") // LONG-长期, SHORT-短期
  isRecommended Boolean  @default(false) // 是否推荐

  // 船公司信息
  carrier     String? // 船公司
  carrierLogo String? // 船公司Logo

  // 运价 - FCL整箱
  price20GP Float? // 20'GP运价
  price40GP Float? // 40'GP运价
  price40HQ Float? // 40'HQ运价
  price45HQ Float? // 45'HQ运价
  currency  String @default("USD") // 币种

  // 成本价
  cost20GP Float? // 20'GP成本
  cost40GP Float? // 40'GP成本
  cost40HQ Float? // 40'HQ成本
  cost45HQ Float? // 45'HQ成本
  isAllIn  Boolean @default(false) // 是否ALL IN价

  // 航程信息
  transitTime Int?    // 航程(天)
  schedule    String? // 船期 (周几，如 "周一/三/五")
  routeCode   String? // 航线代码

  // 船期信息
  vesselName String? // 船名
  voyage     String? // 航次
  sailingDate DateTime? // 开航日
  estimatedDeparture DateTime? // ETD

  // 订舱信息
  bookingAgent String? // 订舱代理
  bookingLink  String? // 订舱链接
  spaceStatus  String  @default("AVAILABLE") // AVAILABLE-充足, LIMITED-紧张, FULL-爆舱, SUSPENDED-停航

  // 文件截止信息
  docCutoffDay  String? // 截文件天 (周几)
  docCutoffTime String? // 截文件时间 (如 "12:00")

  // 提单信息
  billOfLadingType String? // 提单类型 (正本/电放/Sea Waybill)
  shippingTerms    String? // 运输条款 (CY-CY, CFS-CFS等)
  deliveryGuide    String? // 放货指引

  // 附加费和说明
  surcharges String? // 附加费说明 (JSON)
  weightLimit String? // 限重说明
  remarks    String? // 备注

  // 其他信息
  priceTrend String? // 运价趋势 (UP-上涨, DOWN-下跌, STABLE-平稳)
  contactInfo String? // 联系方式
  receiptGuide String? // 收货指引

  // 状态
  status String @default("ACTIVE") // ACTIVE-有效, INACTIVE-无效, EXPIRED-过期

  importBatchId String?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([originPort, destinationPort])
  @@index([validFrom, validTo])
  @@index([status])
  @@index([carrier])
  @@index([isRecommended])
  @@index([spaceStatus])
}

// 订单查询日志
model OrderQueryLog {
  id             String   @id @default(uuid())
  memberId       String
  dzgRequest     String   // JSON字符串存储大掌柜请求参数
  dzgResponse    String?  // JSON字符串存储大掌柜响应（脱敏）
  status         String   @default("SUCCESS")
  errorMessage   String?
  responseTimeMs Int?     // 响应时间（毫秒）
  createdAt      DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([createdAt])
}

// 港口基础表
model Port {
  id          String   @id @default(uuid())
  code        String   @unique // 港口代码
  nameEn      String   // 英文名称
  nameCn      String   // 中文名称
  countryCode String?  // 国家代码
  countryName String?  // 国家名称
  region      String?  // 区域（如：东南亚、欧洲等）
  routeId     String?  // 所属航线
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  route Route? @relation(fields: [routeId], references: [id])

  @@index([code])
  @@index([nameEn])
  @@index([nameCn])
  @@index([region])
  @@index([routeId])
}

// 航线基础表
model Route {
  id          String   @id @default(uuid())
  code        String   @unique // 航线代码
  nameEn      String   // 英文名称
  nameCn      String   // 中文名称
  description String?  // 描述
  regionFrom  String?  // 起始区域
  regionTo    String?  // 目的区域
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ports Port[]

  @@index([code])
  @@index([nameEn])
  @@index([nameCn])
}

// 船公司基础表
model Carrier {
  id          String   @id @default(uuid())
  code        String   @unique // 船公司代码
  name        String   // 船公司名称
  nameEn      String?  // 英文名称
  logo        String?  // Logo URL
  website     String?  // 官网
  contactInfo String?  // 联系方式
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([name])
}

// 会员港口偏好（用于记录查询习惯）
model MemberPortPreference {
  id          String   @id @default(uuid())
  memberId    String
  portCode    String   // 港口代码
  portType    String   // ORIGIN 或 DESTINATION
  queryCount  Int      @default(1) // 查询次数
  lastQueryAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, portCode, portType])
  @@index([memberId])
  @@index([portCode])
}
